@{
    ViewBag.Title = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Store Management Dashboard</h2>

<hr />

<!-- TOTALS SECTION -->
<div style="display:flex; gap:40px; margin-bottom:30px;">

    <div style="padding:15px; border:1px solid gray;">
        <h3>Total Customers</h3>
        <h2>@ViewBag.TotalCustomers</h2>
    </div>

    <div style="padding:15px; border:1px solid gray;">
        <h3>Total Products</h3>
        <h2>@ViewBag.TotalProducts</h2>
    </div>

    <div style="padding:15px; border:1px solid gray;">
        <h3>Total Orders</h3>
        <h2>@ViewBag.TotalOrders</h2>
    </div>

    <div style="padding:15px; border:1px solid gray;">
        <h3>Total Categories</h3>
        <h2>@ViewBag.TotalCategories</h2>
    </div>

    <div style="padding:15px; border:1px solid gray;">
        <h3>Total Revenue</h3>
        <h2>R @ViewBag.TotalRevenue</h2>
    </div>

</div>

<hr />

<!-- CATEGORIES -->
<h3>Categories</h3>

<p>
    @Html.ActionLink("Create New Category", "Create", "Categories")
</p>

<table class="table table-bordered">

    <tr>
        <th>Category Name</th>
        <th>Description</th>
        <th>Created Date</th>
        <th>Is Active</th>
        <th>Actions</th>
    </tr>

    @foreach (var item in ViewBag.Categories)
    {
        <tr>
            <td>@item.CategoryName</td>
            <td>@item.Description</td>
            <td>@item.CreatedDate</td>
            <td>@item.IsActive</td>

            <td>
                @Html.ActionLink("Edit", "Edit", "Categories", new { id = item.CategoryID }, null) |

                @Html.ActionLink("Details", "Details", "Categories", new { id = item.CategoryID }, null) |

                @Html.ActionLink("Delete", "Delete", "Categories", new { id = item.CategoryID }, null)
            </td>
        </tr>
    }

</table>

<hr />

<!-- PRODUCTS -->
<h3>Products</h3>

<p>
    @Html.ActionLink("Create New Product", "Create", "Products")
</p>

<table class="table table-bordered">

    <tr>
        <th>Product Name</th>
        <th>Category</th>
        <th>Price</th>
        <th>Stock</th>
        <th>Actions</th>
    </tr>

    @foreach (var item in ViewBag.Products)
    {
        <tr>
            <td>@item.ProductName</td>
            <td>@item.Category.CategoryName</td>
            <td>R @item.Price</td>
            <td>@item.StockQuantity</td>

            <td>
                @Html.ActionLink("Edit", "Edit", "Products", new { id = item.ProductID }, null) |

                @Html.ActionLink("Details", "Details", "Products", new { id = item.ProductID }, null) |

                @Html.ActionLink("Delete", "Delete", "Products", new { id = item.ProductID }, null)
            </td>
        </tr>
    }

</table>

<hr />

<!-- CUSTOMERS -->
<h3>Customers</h3>

<p>
    @Html.ActionLink("Create New Customer", "Create", "Customers")
</p>

<table class="table table-bordered">

    <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Phone</th>
        <th>Actions</th>
    </tr>

    @foreach (var item in ViewBag.Customers)
    {
        <tr>
            <td>@item.FirstName @item.LastName</td>
            <td>@item.Email</td>
            <td>@item.PhoneNumber</td>

            <td>
                @Html.ActionLink("Edit", "Edit", "Customers", new { id = item.CustomerID }, null) |

                @Html.ActionLink("Details", "Details", "Customers", new { id = item.CustomerID }, null) |

                @Html.ActionLink("Delete", "Delete", "Customers", new { id = item.CustomerID }, null)
            </td>
        </tr>
    }

</table>

<hr />

<!-- ORDERS -->
<h3>Orders</h3>

<p>
    @Html.ActionLink("Create New Order", "Create", "Orders")
</p>

<table class="table table-bordered">

    <tr>
        <th>Order ID</th>
        <th>Customer</th>
        <th>Order Date</th>
        <th>Status</th>
        <th>Total Amount</th>
        <th>Actions</th>
    </tr>

    @foreach (var item in ViewBag.Orders)
    {
        <tr>
            <td>@item.OrderID</td>
            <td>@item.Customer.FirstName @item.Customer.LastName</td>
            <td>@item.OrderDate</td>
            <td>@item.Status</td>
            <td>R @item.TotalAmount</td>

            <td>
                @Html.ActionLink("Edit", "Edit", "Orders", new { id = item.OrderID }, null) |

                @Html.ActionLink("Details", "Details", "Orders", new { id = item.OrderID }, null) |

                @Html.ActionLink("Delete", "Delete", "Orders", new { id = item.OrderID }, null)
            </td>
        </tr>
    }

</table>